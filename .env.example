# Database (SQLite)
DATABASE_URL=file:/data/tsk.db

# NextAuth
NEXTAUTH_SECRET=generate-a-random-32-byte-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Bolt card service
BOLT_API_URL=http://bolt:3001
BOLT_API_KEY=
NEXT_PUBLIC_BOLT_URL=https://bolt.bitcoinekasi.xyz

# Users
ADMIN_NAME=Administrator
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

MARSHALL_NAME=Marshall
MARSHALL_USERNAME=marshall
MARSHALL_PASSWORD=changeme

# Cron secret — must match the bearer token used in the monthly cron job
CRON_SECRET=generate-a-random-hex-secret-here

# Email notifications (Google Workspace SMTP) — attendance submit/reminder/digest emails
# SMTP_USER must be a Google Workspace mailbox with an App Password generated (requires 2-Step Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=attendance@bitcoinekasi.com
SMTP_PASSWORD=
EMAIL_FROM=attendance@bitcoinekasi.com
ATTENDANCE_ALERT_RECIPIENTS=thinus@bitcoinekasi.com
